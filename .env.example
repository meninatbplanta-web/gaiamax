NEXT_PUBLIC_SUPABASE_URL=https://zqkyrewtrudslmblgdxm.supabase.co

# Chave pública "anon" (Settings -> API -> Project API keys -> anon public):
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole_a_anon_key_aqui

# Chave secreta "service_role" (NUNCA expor no front-end; usada só no servidor):
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui
